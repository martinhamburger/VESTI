{
  "extends": "plasmo/templates/tsconfig.base",
  "exclude": [
    "node_modules"
  ],
  "include": [
    ".plasmo/index.d.ts",
    "./**/*.ts",
    "./**/*.tsx"
  ],
  "compilerOptions": {
    "paths": {
      "~*": [
        "./src/*",
        "./*"
      ],
      "@vesti/ui": [
        "../packages/vesti-ui/src/index.ts"
      ]
    },
    "baseUrl": "."
  }
}
