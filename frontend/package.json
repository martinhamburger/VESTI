{
  "name": "vesti",
  "displayName": "Vesti",
  "version": "1.2.0-rc.2",
  "description": "AI Chat Memory - Capture and review your conversations",
  "author": "Vesti",
  "scripts": {
    "dev": "plasmo dev",
    "build": "plasmo build",
    "package": "pnpm run build && plasmo package",
    "eval:prompts": "pnpm exec tsc --project ../scripts/tsconfig.eval.json && node ../.tmp/eval/scripts/eval-prompts.js"
  },
  "dependencies": {
    "@fontsource/inter": "^5.2.8",
    "@fontsource/lora": "^5.2.8",
    "@fontsource/newsreader": "^5.2.10",
    "@fontsource/noto-serif-sc": "^5.2.9",
    "@fontsource/nunito-sans": "^5.2.7",
    "@vesti/ui": "file:../packages/vesti-ui",
    "dexie": "^4.3.0",
    "katex": "^0.16.25",
    "lucide-react": "^0.544.0",
    "plasmo": "0.90.5",
    "react": "18.2.0",
    "react-dom": "18.2.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@ianvs/prettier-plugin-sort-imports": "4.1.1",
    "@tailwindcss/typography": "^0.5.19",
    "@types/chrome": "0.0.258",
    "@types/node": "20.11.5",
    "@types/react": "18.2.48",
    "@types/react-dom": "18.2.18",
    "autoprefixer": "^10.4.20",
    "postcss": "^8.5.0",
    "prettier": "3.2.4",
    "tailwindcss": "^3.4.17",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "5.3.3"
  },
  "manifest": {
    "version": "1.2.0",
    "version_name": "1.2.0-rc.2",
    "host_permissions": [
      "https://vesti-proxy.vercel.app/*",
      "https://dashscope.aliyuncs.com/*",
      "https://api-inference.modelscope.cn/*",
      "https://chatgpt.com/*",
      "https://chat.openai.com/*",
      "https://claude.ai/*",
      "https://gemini.google.com/*",
      "https://chat.deepseek.com/*",
      "https://www.doubao.com/*",
      "https://chat.qwen.ai/*"
    ],
    "permissions": [
      "storage",
      "offscreen",
      "sidePanel",
      "unlimitedStorage"
    ]
  }
}
